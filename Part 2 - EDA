    "geography   = pd.read_csv(DATA_DIR + 'geography.csv')\n",
    "print(\"Load xong!\\n\")\n",
    "\n",
    "# Pre-compute shared columns\n",
    "products['margin_pct'] = (products['price'] - products['cogs']) / products['price'] * 100\n",
